# Copy to .env next to pyproject.toml. Do NOT commit .env.

BRAIN_MCP_POSTGRES_DSN=postgresql+psycopg://brain:YOUR_PASSWORD@<storage-host>:5433/brain
BRAIN_MCP_OLLAMA_BASE_URL=http://<ollama-host>:11434
BRAIN_MCP_MODEL_RERANK=gemma4:e2b
BRAIN_MCP_MODEL_EMBED=nomic-embed-text
BRAIN_MCP_SEARCH_CANDIDATES=8
BRAIN_MCP_SEARCH_RETURN_DEFAULT=5
BRAIN_MCP_MAX_CHUNKS_PER_DOCUMENT=2
BRAIN_MCP_VAULT_PATH=/path/to/your/Brain

# --- Remote HTTP transport (brain-mcp-http) ---
# Only needed for Claude iOS / other remote MCP clients. The stdio server
# (brain-mcp) ignores these.
BRAIN_MCP_HTTP_HOST=127.0.0.1
BRAIN_MCP_HTTP_PORT=8766
# Generate with: openssl rand -hex 32
# http_server.py refuses to start if this is empty.
BRAIN_MCP_REMOTE_BEARER_TOKEN=
