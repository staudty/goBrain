# Copy to .env next to pyproject.toml. Do NOT commit .env.

# HTTP — set HOST=0.0.0.0 if you want the dashboard / API reachable on LAN
BRAIN_HOST=127.0.0.1
BRAIN_PORT=8765

# Vault — point at the folder your sync layer keeps in sync across hosts
BRAIN_VAULT_PATH=/path/to/your/Brain
BRAIN_INBOX_PATH=/path/to/your/Brain/_inbox

# Storage — leave DSN empty to buffer to SQLite until Postgres is reachable
BRAIN_POSTGRES_DSN=
BRAIN_FALLBACK_SQLITE_PATH=/path/to/your/home/.goBrain/buffer.sqlite

# Once your Postgres is up:
# BRAIN_POSTGRES_DSN=postgresql+psycopg://brain:YOUR_PASSWORD@<storage-host>:5433/brain

# Ollama
BRAIN_OLLAMA_BASE_URL=http://127.0.0.1:11434
BRAIN_MODEL_FAST=gemma4:e2b
BRAIN_MODEL_PRIMARY=gemma4:e4b
BRAIN_MODEL_EMBED=nomic-embed-text
BRAIN_EMBED_DIM=768

# llama.cpp heavy tier (optional)
BRAIN_LLAMACPP_BASE_URL=http://127.0.0.1:8081

# Watchers — turn sources on/off independently
BRAIN_WATCH_CLAUDE_CODE=true
BRAIN_CLAUDE_CODE_PROJECTS_DIR=/path/to/your/home/.claude/projects
BRAIN_WATCH_CLAUDE_DESKTOP=true
BRAIN_WATCH_INBOX=true
