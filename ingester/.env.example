# Copy to .env next to pyproject.toml. Do NOT commit .env.

# HTTP
BRAIN_HOST=127.0.0.1
BRAIN_PORT=8765

# Vault — point at the Synology Drive-synced folder on the Mac Mini
BRAIN_VAULT_PATH=/Users/chris/Brain
BRAIN_INBOX_PATH=/Users/chris/Brain/_inbox

# Storage — leave DSN empty until the NAS Postgres is up. Ingester buffers to SQLite.
BRAIN_POSTGRES_DSN=
BRAIN_FALLBACK_SQLITE_PATH=/Users/chris/.goBrain/buffer.sqlite

# After NAS RAM is installed and Postgres is up, set this to:
# BRAIN_POSTGRES_DSN=postgresql+psycopg://brain:YOUR_PASSWORD@192.168.1.178:5433/brain

# Ollama
BRAIN_OLLAMA_BASE_URL=http://127.0.0.1:11434
BRAIN_MODEL_FAST=gemma4:e2b
BRAIN_MODEL_PRIMARY=gemma4:e4b
BRAIN_MODEL_EMBED=nomic-embed-text
BRAIN_EMBED_DIM=768

# llama.cpp heavy tier
BRAIN_LLAMACPP_BASE_URL=http://127.0.0.1:8081

# Watchers — turn sources on/off independently
BRAIN_WATCH_CLAUDE_CODE=true
BRAIN_CLAUDE_CODE_PROJECTS_DIR=/Users/chris/.claude/projects
BRAIN_WATCH_CLAUDE_DESKTOP=true
BRAIN_WATCH_INBOX=true
