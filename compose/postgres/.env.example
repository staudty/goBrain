# Copy to .env next to docker-compose.yml on your storage host and fill in.
# Do NOT commit .env — it's in .gitignore.

POSTGRES_DB=brain
POSTGRES_USER=brain

# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=

# Expose on 5433 so it doesn't collide with any other Postgres running on the NAS.
POSTGRES_PORT=5433

# Only used if you enable the admin profile: `docker compose --profile admin up -d`
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=
PGADMIN_PORT=5050
